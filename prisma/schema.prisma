// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Модель категории
model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
}

// Модель блюда
model Product {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image       String
  isAvailable Boolean     @default(true)
  isVisible   Boolean     @default(true)
  dayOfWeek   Int
  weekType    Int
  calories    Int?
  weight      Int?
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Индексы для часто используемых запросов
  @@index([categoryId])
  @@index([isVisible, isAvailable])
  @@index([dayOfWeek, weekType])
  @@index([name])
}

// Настройки меню
model MenuSettings {
  id            String   @id @default(uuid())
  publishedWeek Int      @default(1)
  updatedAt     DateTime @updatedAt
}

// Статусы заказа
enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

// Модель временного интервала
model TimeSlot {
  id        String  @id @default(uuid())
  label     String
  startTime String
  endTime   String
  capacity  Int
  isEnabled Boolean @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
}

// Модель заказа
model Order {
  id            String      @id @default(uuid())
  orderNumber   Int         @unique @default(autoincrement())
  createdAt     DateTime    @default(now())
  totalPrice    Decimal     @db.Decimal(10, 2)
  pickupTime    DateTime
  status        OrderStatus @default(PENDING)
  userSub       String?
  cancelReason  String?
  orderItems    OrderItem[]
  timeSlotId    String?
  timeSlot      TimeSlot?   @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)
  scheduledDate DateTime?

  // Индексы для фильтрации и сортировки
  @@index([userSub])
  @@index([status])
  @@index([createdAt])
  @@index([pickupTime])
  @@index([timeSlotId])
  @@index([scheduledDate])
}

// Связующая таблица
model OrderItem {
  id           String  @id @default(uuid())
  quantity     Int
  price        Decimal @db.Decimal(10, 2)
  productName  String
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}